{
  "name": "@specific.dev/replacebase",
  "version": "0.1.0",
  "description": "Drop-in replacement for Supabase's backend as a Typescript library",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "supabase",
    "postgrest",
    "gotrue",
    "drizzle"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/specific-dev/replacebase"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.997.0",
    "@hono/node-server": "^1.19.9",
    "@hono/node-ws": "^1.3.0",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.4.19",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.2",
    "jose": "^6.1.3",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.15",
    "@supabase/supabase-js": "^2.97.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.3.0",
    "drizzle-kit": "^0.31.9",
    "s3rver": "^3.7.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}